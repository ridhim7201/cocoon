# Leave this unset for local development — Vite's dev server proxies
# "/api/*" requests to http://localhost:3001 automatically (see vite.config.js).
#
# For Cloud Run deployment, set this to your deployed BACKEND service URL
# (no trailing slash), e.g.:
# VITE_API_URL=https://cocoon-backend-xxxxx-uc.a.run.app
VITE_API_URL=
