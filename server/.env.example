# Get a free key at https://aistudio.google.com/apikey
# Free tier limits (Gemini 2.0 Flash, subject to change by Google):
#   15 requests/minute, 1 million tokens/minute, 1500 requests/day
GEMINI_API_KEY=your_gemini_api_key_here
PORT=3001

# Comma-separated list of allowed frontend origins.
# For local dev, the defaults below work. For Cloud Run deployment,
# add your deployed frontend URL, e.g.:
# ALLOWED_ORIGINS=http://localhost:5173,https://cocoon-frontend-xxxxx.run.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
